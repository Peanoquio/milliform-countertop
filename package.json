{
  "name": "milliform-countertop",
  "version": "1.0.0",
  "private": true,
  "homepage": "/",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "react-scripts": "5.0.1",
    "yaml": "^2.9.0"
  },
  "scripts": {
    "gen:hero": "node scripts/generate-hero-images.mjs",
    "start": "npm run gen:hero && react-scripts start",
    "build": "npm run gen:hero && react-scripts build",
    "build:ghpages": "npm run gen:hero && PUBLIC_URL=/milliform-countertop react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "deploy:cf": "npm run build && wrangler pages deploy build --project-name=milliform-countertop",
    "gen:images": "node scripts/generate-images.mjs",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "prepare": "husky install"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@google/genai": "^1.10.0",
    "gh-pages": "^6.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "sharp": "^0.33.5"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint --fix",
      "git add"
    ]
  }
}
