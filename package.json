{
  "name": "milliform-countertop",
  "version": "1.0.0",
  "private": true,
  "homepage": ".",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:ghpages": "PUBLIC_URL=/milliform-countertop react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "deploy:cf": "npm run build && wrangler pages deploy build --project-name=milliform-countertop",
    "gen:images": "node scripts/generate-images.mjs"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@google/genai": "^1.10.0",
    "gh-pages": "^6.1.1",
    "sharp": "^0.33.5"
  }
}
