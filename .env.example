# Cloudflare Turnstile captcha site key
# Get this from your Cloudflare Turnstile dashboard:
# https://dash.cloudflare.com/?to=/:account/turnstile
#
# Steps to set up:
# 1. Log in to Cloudflare dashboard
# 2. Go to Turnstile > Create Site
# 3. Enter site name: "Milliform Contact Form"
# 4. Copy the Site Key
# 5. Paste it below (without the REACT_APP_ prefix)
#
# For local development, copy this to .env:
# REACT_APP_TURNSTILE_SITE_KEY=your_site_key_here
#
# For production deployments, set this as an environment variable in your hosting platform.
# Cloudflare Turnstile site key
# For development/testing, use the public test key below (will always pass)
# For production, replace with your real site key from https://dash.cloudflare.com/turnstile
REACT_APP_TURNSTILE_SITE_KEY=1x00000000000000000000AA
